# Application settings
# NASベースパスを設定してください
# macOS例: /Volumes/disk1/DESIGN
# Windows例（マップ済みドライブ）: Z:\DESIGN
# Windows例（UNCパス）: \\HIYOSHI1\disk1\DESIGN
NAS_BASE_PATH=/Volumes/disk1/DESIGN

# サーバーを別ポートで起動したい場合は PORT を指定します
# PORT=3000

# LINE Messaging API (LINE Developers コンソールで発行)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
